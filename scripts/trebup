#!/bin/sh
# trebup — installer for treb, the smart-contract deployment tool
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/OWNER/REPO/main/scripts/trebup | sh
#
# Environment variables:
#   TREB_VERSION     Install a specific version tag (default: latest release)
#   TREB_INSTALL_DIR Install directory (default: ~/.local/bin)
#   TREB_REPO        GitHub repository (default: treb-rs/treb-cli-rs)

set -e

REPO="${TREB_REPO:-treb-rs/treb-cli-rs}"
BINARY="treb"

# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------

detect_target() {
    _os="$(uname -s)"
    _arch="$(uname -m)"

    case "$_os" in
        Linux)
            case "$_arch" in
                x86_64)          echo "x86_64-unknown-linux-musl" ;;
                aarch64|arm64)   echo "aarch64-unknown-linux-musl" ;;
                *)
                    echo "Unsupported platform: $_os/$_arch" >&2
                    exit 1
                    ;;
            esac
            ;;
        Darwin)
            case "$_arch" in
                x86_64)          echo "x86_64-apple-darwin" ;;
                arm64|aarch64)   echo "aarch64-apple-darwin" ;;
                *)
                    echo "Unsupported platform: $_os/$_arch" >&2
                    exit 1
                    ;;
            esac
            ;;
        *)
            echo "Unsupported platform: $_os" >&2
            exit 1
            ;;
    esac
}

TARGET="$(detect_target)"

# ---------------------------------------------------------------------------
# Resolve version
# ---------------------------------------------------------------------------

if [ -n "$TREB_VERSION" ]; then
    VERSION="$TREB_VERSION"
else
    printf "Fetching latest treb version... "
    VERSION="$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" \
        | grep '"tag_name"' \
        | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')"
    echo "$VERSION"
fi

if [ -z "$VERSION" ]; then
    echo "error: could not determine version to install" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Resolve install directory
# ---------------------------------------------------------------------------

INSTALL_DIR="${TREB_INSTALL_DIR:-$HOME/.local/bin}"
mkdir -p "$INSTALL_DIR"

# ---------------------------------------------------------------------------
# Download
# ---------------------------------------------------------------------------

ARCHIVE="treb-${VERSION}-${TARGET}.tar.gz"
CHECKSUM_FILE="${ARCHIVE%.tar.gz}.sha256"
BASE_URL="https://github.com/${REPO}/releases/download/${VERSION}"

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT INT TERM

echo "Downloading treb ${VERSION} for ${TARGET}..."
curl -fsSL "${BASE_URL}/${ARCHIVE}" -o "${TMP_DIR}/${ARCHIVE}"
curl -fsSL "${BASE_URL}/${CHECKSUM_FILE}" -o "${TMP_DIR}/${CHECKSUM_FILE}"

# ---------------------------------------------------------------------------
# Checksum verification
# ---------------------------------------------------------------------------

echo "Verifying checksum..."
cd "$TMP_DIR"

if command -v sha256sum >/dev/null 2>&1; then
    sha256sum -c "$CHECKSUM_FILE"
elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 -c "$CHECKSUM_FILE"
else
    echo "error: no SHA-256 tool found (sha256sum or shasum required)" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Extract and install
# ---------------------------------------------------------------------------

tar xzf "$ARCHIVE"
install -m 755 "$BINARY" "${INSTALL_DIR}/${BINARY}"

echo ""
echo "treb ${VERSION} installed to ${INSTALL_DIR}/${BINARY}"
