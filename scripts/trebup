#!/bin/sh
# trebup — installer for treb, the smart-contract deployment tool
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/trebuchet-org/treb-cli-rs/main/scripts/trebup | sh
#
# Environment variables:
#   TREB_VERSION     Install a specific version tag (default: latest release)
#   TREB_INSTALL_DIR Install directory (default: ~/.local/bin)
#   TREB_REPO        GitHub repository (default: trebuchet-org/treb-cli-rs)

set -e

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

usage() {
    cat <<'USAGE'
trebup — installer for treb, the smart-contract deployment tool

USAGE:
    trebup [OPTIONS]

OPTIONS:
    -h, --help    Print this help message

ENVIRONMENT VARIABLES:
    TREB_VERSION      Install a specific version tag (default: latest release)
    TREB_INSTALL_DIR  Install directory (default: ~/.local/bin)
    TREB_REPO         GitHub repository (default: trebuchet-org/treb-cli-rs)

EXAMPLES:
    # Install latest version
    curl -fsSL https://raw.githubusercontent.com/trebuchet-org/treb-cli-rs/main/scripts/trebup | sh

    # Install a specific version
    TREB_VERSION=v0.1.0 trebup

    # Install to a custom directory
    TREB_INSTALL_DIR=/usr/local/bin trebup
USAGE
}

for arg in "$@"; do
    case "$arg" in
        -h|--help)
            usage
            exit 0
            ;;
    esac
done

REPO="${TREB_REPO:-trebuchet-org/treb-cli-rs}"
BINARY="treb"

# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------

detect_platform() {
    _os="$(uname -s)"
    _arch="$(uname -m)"

    case "$_os" in
        Linux)
            case "$_arch" in
                x86_64)          echo "linux-amd64" ;;
                aarch64|arm64)   echo "linux-arm64" ;;
                *)
                    echo "Unsupported platform: $_os/$_arch" >&2
                    exit 1
                    ;;
            esac
            ;;
        Darwin)
            case "$_arch" in
                x86_64)          echo "darwin-amd64" ;;
                arm64|aarch64)   echo "darwin-arm64" ;;
                *)
                    echo "Unsupported platform: $_os/$_arch" >&2
                    exit 1
                    ;;
            esac
            ;;
        *)
            echo "Unsupported platform: $_os" >&2
            exit 1
            ;;
    esac
}

OS_ARCH="$(detect_platform)"

# ---------------------------------------------------------------------------
# Resolve version
# ---------------------------------------------------------------------------

if [ -n "$TREB_VERSION" ]; then
    VERSION="$TREB_VERSION"
else
    printf "Fetching latest treb version... "
    VERSION="$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" \
        | grep '"tag_name"' \
        | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')"
    echo "$VERSION"
fi

if [ -z "$VERSION" ]; then
    echo "error: could not determine version to install" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Resolve install directory
# ---------------------------------------------------------------------------

INSTALL_DIR="${TREB_INSTALL_DIR:-$HOME/.local/bin}"
mkdir -p "$INSTALL_DIR"

# ---------------------------------------------------------------------------
# Download
# ---------------------------------------------------------------------------

ARCHIVE="treb-${VERSION}-${OS_ARCH}.tar.gz"
CHECKSUM_FILE="treb-${VERSION}-${OS_ARCH}.sha256"
BASE_URL="https://github.com/${REPO}/releases/download/${VERSION}"

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT INT TERM

echo "Downloading treb ${VERSION} for ${OS_ARCH}..."
curl -fsSL "${BASE_URL}/${ARCHIVE}" -o "${TMP_DIR}/${ARCHIVE}"
curl -fsSL "${BASE_URL}/${CHECKSUM_FILE}" -o "${TMP_DIR}/${CHECKSUM_FILE}"

# ---------------------------------------------------------------------------
# Checksum verification
# ---------------------------------------------------------------------------

echo "Verifying checksum..."
cd "$TMP_DIR"

if command -v sha256sum >/dev/null 2>&1; then
    sha256sum -c "$CHECKSUM_FILE"
elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 -c "$CHECKSUM_FILE"
else
    echo "error: no SHA-256 tool found (sha256sum or shasum required)" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Extract and install
# ---------------------------------------------------------------------------

tar xzf "$ARCHIVE"
install -m 755 "$BINARY" "${INSTALL_DIR}/${BINARY}"

echo ""
echo "treb ${VERSION} installed to ${INSTALL_DIR}/${BINARY}"

# ---------------------------------------------------------------------------
# Install shell completions
# ---------------------------------------------------------------------------

if [ -d "completions" ]; then
    zsh_completion_dir() {
        _fallback_dir="$HOME/.zsh/completions"
        _zsh_fpath=""

        if [ -n "${FPATH:-}" ]; then
            _zsh_fpath="$(printf '%s' "$FPATH" | tr ':' '\n')"
        elif command -v zsh >/dev/null 2>&1; then
            if _zsh_fpath="$(zsh -ic 'print -rl -- $fpath' </dev/null 2>/dev/null)"; then
                :
            elif _zsh_fpath="$(zsh -fc 'print -rl -- $fpath' 2>/dev/null)"; then
                :
            else
                _zsh_fpath=""
            fi
        fi

        if [ -n "$_zsh_fpath" ]; then
            _old_ifs=$IFS
            IFS='
'
            for _dir in $_zsh_fpath; do
                if [ -n "$_dir" ] && [ -d "$_dir" ] && [ -w "$_dir" ]; then
                    IFS=$_old_ifs
                    printf '%s\n' "$_dir"
                    return 0
                fi
            done
            IFS=$_old_ifs
        fi

        printf '%s\n' "$_fallback_dir"
        return 1
    }

    install_completions() {
        _shell="$(basename "${SHELL:-}")"

        case "$_shell" in
            bash)
                _comp_dir="${XDG_DATA_HOME:-$HOME/.local/share}/bash-completion/completions"
                if [ -f "completions/treb.bash" ]; then
                    mkdir -p "$_comp_dir"
                    cp "completions/treb.bash" "$_comp_dir/treb"
                    echo "Bash completions installed to $_comp_dir/treb"
                fi
                ;;
            zsh)
                if [ -f "completions/_treb" ]; then
                    if _comp_dir="$(zsh_completion_dir)"; then
                        _needs_setup=0
                    else
                        _needs_setup=1
                    fi

                    mkdir -p "$_comp_dir"
                    cp "completions/_treb" "$_comp_dir/_treb"
                    echo "Zsh completions installed to $_comp_dir/_treb"

                    if [ "$_needs_setup" -eq 1 ]; then
                        echo "No writable zsh completion directory was found in fpath."
                        echo "If ~/.zsh/completions is not already in fpath, add this to ~/.zshrc:"
                        echo "  fpath=(~/.zsh/completions \$fpath)"
                        echo "Then refresh completions with:"
                        echo "  autoload -Uz compinit && compinit"
                    fi
                fi
                ;;
            fish)
                _comp_dir="${XDG_CONFIG_HOME:-$HOME/.config}/fish/completions"
                if [ -f "completions/treb.fish" ]; then
                    mkdir -p "$_comp_dir"
                    cp "completions/treb.fish" "$_comp_dir/treb.fish"
                    echo "Fish completions installed to $_comp_dir/treb.fish"
                fi
                ;;
            *)
                echo "Shell completions available in the archive but not auto-installed for $_shell"
                ;;
        esac
    }

    install_completions
fi

# ---------------------------------------------------------------------------
# PATH check
# ---------------------------------------------------------------------------

case ":$PATH:" in
    *":${INSTALL_DIR}:"*)
        ;;
    *)
        echo ""
        echo "NOTE: ${INSTALL_DIR} is not in your PATH."
        echo "Add it with:  export PATH=\"${INSTALL_DIR}:\$PATH\""
        ;;
esac
