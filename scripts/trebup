#!/usr/bin/env bash
set -eo pipefail

# trebup — unified installer for treb (Rust v2 + Go v1)
#
# Install (use bash, not sh):
#   curl -fsSL https://raw.githubusercontent.com/trebuchet-org/treb-cli-rs/main/scripts/trebup | bash
#
# Version scheme:
#   v2-nightly-{hash}--foundry-nightly-{hash}   Rust nightly + foundry nightly
#   v2-nightly-{hash}--foundry-v1.5.1           Rust nightly + foundry stable
#   v2.1.0--foundry-v1.5.1                      Rust stable + foundry stable
#   v1-nightly                                   Go nightly (system forge)

TREBUP_VERSION="2.0.0"

TREB_DIR="${TREB_DIR:-$HOME/.treb}"
TREB_BIN_DIR="$TREB_DIR/bin"
TREB_VERSIONS_DIR="$TREB_DIR/versions"
TREB_ACTIVE_FILE="$TREB_DIR/.active"

RUST_REPO="trebuchet-org/treb-cli-rs"
GO_REPO="trebuchet-org/treb-cli"

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  need_cmd curl
  need_cmd tar

  local cmd="install"
  local install_version=""
  local foundry_channel="stable"

  while [[ -n $1 ]]; do
    case $1 in
      --)               shift; break;;
      -h|--help)        usage; exit 0;;
      -v|--version)     echo "trebup $TREBUP_VERSION"; exit 0;;
      -U|--update)      cmd="update"; shift; continue;;
      -l|--list)        cmd="list"; shift; continue;;
      -u|--use)         shift; cmd="use"; install_version="$1";;
      -i|--install)     shift; install_version="$1";;
      --foundry)        shift; foundry_channel="$1";;
      *)                warn "unknown option: $1"; usage; exit 1;;
    esac
    shift
  done

  banner

  case "$cmd" in
    list)    do_list; exit 0;;
    use)     do_use "$install_version"; exit 0;;
    update)  do_update; exit 0;;
    install) ;;
  esac

  # Migrate old installations on first run
  migrate_if_needed

  # Resolve what to install
  local tag="" repo=""
  resolve_install "$install_version" "$foundry_channel" tag repo

  if [ -z "$tag" ]; then
    err "no release found. The nightly CI may not have published a release yet.
  Check https://github.com/${RUST_REPO}/releases for available versions,
  or install a specific tag with: trebup --install <tag>"
  fi

  say "installing treb ($tag)"

  # Detect platform
  local platform arch
  detect_platform platform arch

  # Download + extract
  # Go repo uses underscores: treb_tag_platform_arch.tar.gz
  # Rust repo uses hyphens: treb-tag-platform-arch.tar.gz
  local archive checksum_file
  case "$repo" in
    *treb-cli-rs)
      archive="treb-${tag}-${platform}-${arch}.tar.gz"
      checksum_file="treb-${tag}-${platform}-${arch}.sha256"
      ;;
    *)
      archive="treb_${tag}_${platform}_${arch}.tar.gz"
      checksum_file="treb_${tag}_${platform}_${arch}.sha256"
      ;;
  esac
  local base_url="https://github.com/${repo}/releases/download/${tag}"
  local version_dir="$TREB_VERSIONS_DIR/$tag"

  local tmp_dir
  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "$tmp_dir"' EXIT INT TERM

  say "downloading $archive..."
  curl -fsSL "${base_url}/${archive}" -o "${tmp_dir}/${archive}"
  if curl -fsSL "${base_url}/${checksum_file}" -o "${tmp_dir}/${checksum_file}" 2>/dev/null; then
    verify_checksum "$tmp_dir" "$checksum_file"
  fi

  # Extract to version dir
  ensure mkdir -p "$version_dir"
  ensure tar xzf "${tmp_dir}/${archive}" -C "$version_dir"

  # Activate
  activate "$tag"

  # Install shell completions from archive
  if [ -d "$version_dir/completions" ]; then
    install_completions "$version_dir/completions"
  fi

  say "done! treb $tag installed to $TREB_BIN_DIR/treb"
  check_path
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

do_list() {
  if [ ! -d "$TREB_VERSIONS_DIR" ]; then
    say "no versions installed"
    return
  fi

  local active
  active="$(cat "$TREB_ACTIVE_FILE" 2>/dev/null || echo "")"

  say "installed versions:"
  for dir in "$TREB_VERSIONS_DIR"/*/; do
    [ -d "$dir" ] || continue
    local v
    v="$(basename "$dir")"
    local marker="  "
    [ "$v" = "$active" ] && marker="* "

    # Detect runtime from version prefix
    local info=""
    case "$v" in
      v1*)  info=" (go, system forge)" ;;
      *--foundry-nightly*) info=" (foundry nightly)" ;;
      *--foundry-v*)
        local fv="${v##*--foundry-}"
        info=" (foundry $fv)" ;;
    esac

    echo "  ${marker}${v}${info}"
  done
}

do_use() {
  local version="$1"
  if [ -z "$version" ]; then
    err "version not specified. Run 'trebup --list' to see installed versions."
  fi

  local version_dir="$TREB_VERSIONS_DIR/$version"
  if [ ! -d "$version_dir" ]; then
    err "version '$version' not installed. Run 'trebup --list' to see installed versions."
  fi

  activate "$version"
  say "switched to treb $version"
}

do_update() {
  local url="https://raw.githubusercontent.com/${RUST_REPO}/main/scripts/trebup"
  say "updating trebup..."
  ensure curl -fsSL "$url" -o "$TREB_BIN_DIR/trebup.tmp"
  ensure chmod +x "$TREB_BIN_DIR/trebup.tmp"
  ensure mv "$TREB_BIN_DIR/trebup.tmp" "$TREB_BIN_DIR/trebup"
  say "updated trebup to latest version"
}

# ---------------------------------------------------------------------------
# Version resolution
# ---------------------------------------------------------------------------

resolve_install() {
  local version="$1"
  local foundry_channel="$2"
  local -n _tag=$3
  local -n _repo=$4

  # Default: latest Rust release (nightly or stable)
  if [ -z "$version" ]; then
    version="latest"
  fi

  # Aliases
  case "$version" in
    nightly)      version="v2-nightly" ;;
    go-nightly)   version="v1-nightly" ;;
    latest)
      # Find the latest release regardless of naming scheme
      _repo="$RUST_REPO"
      local resolved
      resolved="$(find_latest_release "$RUST_REPO" "^v")"
      if [ -z "$resolved" ]; then
        err "no releases found at $RUST_REPO"
      fi
      _tag="$resolved"
      say "resolved latest → $resolved"
      return
      ;;
  esac

  # Route by major version
  case "$version" in
    v1*)
      _repo="$GO_REPO"
      # Go has no foundry dimension — map to Go's current tag format
      if [[ "$version" == "v1-nightly" ]]; then
        _tag="nightly"  # Go repo uses bare "nightly" tag
      else
        _tag="$version"
      fi
      return
      ;;
    v2*)
      _repo="$RUST_REPO"
      ;;
    *)
      err "cannot determine repo for version: $version"
      ;;
  esac

  # Rust: resolve foundry channel into a full FQID tag
  if [[ "$version" == v2-nightly* && "$version" != *--foundry-* ]]; then
    # Try FQID format first, fall back to legacy tag format
    local pattern resolved
    if [ "$foundry_channel" = "nightly" ]; then
      pattern="v2-nightly-.*--foundry-nightly-"
    else
      pattern="v2-nightly-.*--foundry-v"
    fi

    resolved="$(find_latest_release "$RUST_REPO" "$pattern")"
    if [ -z "$resolved" ]; then
      # Fall back to latest release (pre-FQID tags like v0.1.0)
      say "no FQID release found, falling back to latest release..."
      resolved="$(find_latest_release "$RUST_REPO" "^v")"
    fi
    if [ -z "$resolved" ]; then
      err "no release found for treb v2 nightly (foundry $foundry_channel)"
    fi
    _tag="$resolved"
  elif [[ "$version" == v2.* && "$version" != *--foundry-* ]]; then
    # Stable version — try FQID, fall back to exact tag
    local pattern resolved
    if [ "$foundry_channel" = "nightly" ]; then
      pattern="${version}--foundry-nightly-"
    else
      pattern="${version}--foundry-v"
    fi

    resolved="$(find_latest_release "$RUST_REPO" "$pattern")"
    if [ -z "$resolved" ]; then
      # Fall back to exact version tag (pre-FQID)
      resolved="$version"
    fi
    _tag="$resolved"
  else
    # Fully qualified — use as-is
    _tag="$version"
  fi
}

find_latest_release() {
  local repo="$1"
  local pattern="$2"

  curl -fsSL "https://api.github.com/repos/${repo}/releases?per_page=30" 2>/dev/null \
    | grep '"tag_name"' \
    | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/' \
    | grep -E "$pattern" \
    | head -1
}

# ---------------------------------------------------------------------------
# Activate a version
# ---------------------------------------------------------------------------

activate() {
  local version="$1"
  local version_dir="$TREB_VERSIONS_DIR/$version"

  ensure mkdir -p "$TREB_BIN_DIR"

  if [ -f "$version_dir/treb" ]; then
    ensure cp "$version_dir/treb" "$TREB_BIN_DIR/treb"
    ensure chmod +x "$TREB_BIN_DIR/treb"
  elif [ -f "$version_dir/treb-cli" ]; then
    ensure cp "$version_dir/treb-cli" "$TREB_BIN_DIR/treb"
    ensure chmod +x "$TREB_BIN_DIR/treb"
  else
    err "no treb binary found in $version_dir"
  fi

  echo "$version" > "$TREB_ACTIVE_FILE"
}

# ---------------------------------------------------------------------------
# Migration
# ---------------------------------------------------------------------------

migrate_if_needed() {
  local migrated=0

  # 1. Migrate old bare version directories (Go trebup layout)
  if [ -d "$TREB_VERSIONS_DIR" ]; then
    for dir in "$TREB_VERSIONS_DIR"/*/; do
      [ -d "$dir" ] || continue
      local v
      v="$(basename "$dir")"

      # Skip if already in FQID format
      [[ "$v" == v1-* || "$v" == v2-* || "$v" == v1.* || "$v" == v2.* ]] && continue

      # Probe the binary
      local detected=""
      if [ -f "$dir/treb" ]; then
        detected="$("$dir/treb" version 2>/dev/null | head -1 || echo "")"
      fi

      local new_name=""
      if [[ "$detected" == *"foundry"* || "$detected" == *"v2"* ]]; then
        # Rust binary — try to extract commit hash
        local hash
        hash="$(echo "$detected" | grep -o '[0-9a-f]\{7\}' | head -1 || echo "unknown")"
        new_name="v2-nightly-${hash}--foundry-unknown"
      else
        # Assume Go
        new_name="v1-${v}"
      fi

      if [ -n "$new_name" ] && [ ! -d "$TREB_VERSIONS_DIR/$new_name" ]; then
        mv "$dir" "$TREB_VERSIONS_DIR/$new_name"
        say "migrated $v → $new_name"
        migrated=1
      fi
    done
  fi

  # 2. Migrate old ~/.local/bin/treb install
  if [ -f "$HOME/.local/bin/treb" ] && [ ! -f "$TREB_BIN_DIR/treb" ]; then
    local detected=""
    detected="$("$HOME/.local/bin/treb" version 2>/dev/null | head -1 || echo "")"

    local fqid="v2-nightly-unknown--foundry-unknown"
    if [[ "$detected" == *"v1"* ]]; then
      fqid="v1-migrated"
    fi

    ensure mkdir -p "$TREB_VERSIONS_DIR/$fqid"
    cp "$HOME/.local/bin/treb" "$TREB_VERSIONS_DIR/$fqid/treb"
    chmod +x "$TREB_VERSIONS_DIR/$fqid/treb"

    ensure mkdir -p "$TREB_BIN_DIR"
    cp "$TREB_VERSIONS_DIR/$fqid/treb" "$TREB_BIN_DIR/treb"
    chmod +x "$TREB_BIN_DIR/treb"
    echo "$fqid" > "$TREB_ACTIVE_FILE"

    say "migrated ~/.local/bin/treb → $fqid"
    migrated=1
  fi

  # 3. Replace old trebup if present
  if [ -f "$TREB_BIN_DIR/trebup" ]; then
    local old_version
    old_version="$(grep 'TREBUP_INSTALLER_VERSION=' "$TREB_BIN_DIR/trebup" 2>/dev/null | head -1 || echo "")"
    if [[ "$old_version" == *"0.1.0"* ]]; then
      # Old Go trebup — will be replaced when new trebup installs itself
      say "replacing old trebup (v0.1.0)"
      migrated=1
    fi
  fi

  # 4. Write .active if missing
  if [ ! -f "$TREB_ACTIVE_FILE" ] && [ -f "$TREB_BIN_DIR/treb" ]; then
    local detected=""
    detected="$("$TREB_BIN_DIR/treb" version 2>/dev/null | head -1 || echo "")"
    # Best effort — just mark it
    echo "unknown" > "$TREB_ACTIVE_FILE"
  fi

  # 5. Clean up cargo install artifacts
  rm -f "$TREB_DIR/.crates.toml" "$TREB_DIR/.crates2.json" 2>/dev/null

  if [ "$migrated" -eq 1 ]; then
    say "migration complete"
    echo ""
  fi
}

# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------

detect_platform() {
  local -n _platform=$1
  local -n _arch=$2

  local os
  os="$(uname -s)"
  local machine
  machine="$(uname -m)"

  case "$os" in
    Linux)   _platform="linux" ;;
    Darwin)  _platform="darwin" ;;
    MINGW*|MSYS*|CYGWIN*) _platform="windows" ;;
    *)       err "unsupported OS: $os" ;;
  esac

  case "$machine" in
    x86_64)
      # Check for Rosetta
      if [ "$(sysctl -n sysctl.proc_translated 2>/dev/null)" = "1" ]; then
        _arch="arm64"
      else
        _arch="amd64"
      fi
      ;;
    aarch64|arm64) _arch="arm64" ;;
    *)             err "unsupported architecture: $machine" ;;
  esac
}

# ---------------------------------------------------------------------------
# Checksum verification
# ---------------------------------------------------------------------------

verify_checksum() {
  local dir="$1"
  local checksum_file="$2"

  cd "$dir"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum -c "$checksum_file" >/dev/null 2>&1 || err "checksum verification failed"
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 -c "$checksum_file" >/dev/null 2>&1 || err "checksum verification failed"
  else
    warn "no SHA-256 tool found, skipping checksum verification"
  fi
}

# ---------------------------------------------------------------------------
# Shell completions
# ---------------------------------------------------------------------------

install_completions() {
  local comp_dir="$1"
  local shell
  shell="$(basename "${SHELL:-}")"

  case "$shell" in
    bash)
      local bash_dir="${XDG_DATA_HOME:-$HOME/.local/share}/bash-completion/completions"
      if [ -f "$comp_dir/treb.bash" ]; then
        mkdir -p "$bash_dir"
        cp "$comp_dir/treb.bash" "$bash_dir/treb"
        say "bash completions installed"
      fi
      ;;
    zsh)
      if [ -f "$comp_dir/_treb" ]; then
        local zsh_dir="$HOME/.zsh/completions"
        mkdir -p "$zsh_dir"
        cp "$comp_dir/_treb" "$zsh_dir/_treb"
        say "zsh completions installed to $zsh_dir/_treb"
      fi
      ;;
    fish)
      local fish_dir="${XDG_CONFIG_HOME:-$HOME/.config}/fish/completions"
      if [ -f "$comp_dir/treb.fish" ]; then
        mkdir -p "$fish_dir"
        cp "$comp_dir/treb.fish" "$fish_dir/treb.fish"
        say "fish completions installed"
      fi
      ;;
  esac
}

# ---------------------------------------------------------------------------
# PATH check
# ---------------------------------------------------------------------------

check_path() {
  case ":$PATH:" in
    *":${TREB_BIN_DIR}:"*) return ;;
  esac

  # Auto-add to shell profile
  local profile=""
  local shell_name
  shell_name="$(basename "${SHELL:-}")"

  case "$shell_name" in
    zsh)  profile="${ZDOTDIR:-$HOME}/.zshenv" ;;
    bash) profile="$HOME/.bashrc" ;;
    fish) profile="${XDG_CONFIG_HOME:-$HOME/.config}/fish/config.fish" ;;
    *)    profile="$HOME/.profile" ;;
  esac

  if [ -n "$profile" ]; then
    if ! grep -q "$TREB_BIN_DIR" "$profile" 2>/dev/null; then
      echo "" >> "$profile"
      if [ "$shell_name" = "fish" ]; then
        echo "fish_add_path -a $TREB_BIN_DIR" >> "$profile"
      else
        echo "export PATH=\"\$PATH:$TREB_BIN_DIR\"" >> "$profile"
      fi
      say "added $TREB_BIN_DIR to PATH in $profile"
      say "run 'source $profile' or start a new terminal to use treb"
    fi
  fi
}

# ---------------------------------------------------------------------------
# Self-install
# ---------------------------------------------------------------------------

install_trebup() {
  ensure mkdir -p "$TREB_BIN_DIR"

  # If running from a real file (not piped), just copy it
  if [ -f "$0" ] && [ "$0" != "bash" ] && [ "$0" != "/dev/stdin" ]; then
    cp "$0" "$TREB_BIN_DIR/trebup"
    chmod +x "$TREB_BIN_DIR/trebup"
    return
  fi

  # Piped from curl — download trebup to ~/.treb/bin/
  local url="https://raw.githubusercontent.com/${RUST_REPO}/main/scripts/trebup"
  curl -fsSL "$url" -o "$TREB_BIN_DIR/trebup"
  chmod +x "$TREB_BIN_DIR/trebup"
}

# ---------------------------------------------------------------------------
# UI
# ---------------------------------------------------------------------------

banner() {
  if [ -t 2 ] && [ "${NO_COLOR:-}" = "" ]; then
    # Bold cyan for TREB, dim for UCHET
    local B='\033[1;36m' D='\033[2;37m' R='\033[0m'
    printf '\n'
    printf " ${B}▀█▀ █▀▄ █▀▀ █▀▄${D} █ █ █▀▀ █ █ █▀▀ ▀█▀${R}\n"
    printf "  ${B}█  █▀▄ █▀▀ █▀▄${D} █ █ █   █▀█ █▀▀  █${R}\n"
    printf "  ${B}▀  ▀ ▀ ▀▀▀ ▀▀ ${D} ▀▀▀ ▀▀▀ ▀ ▀ ▀▀▀  ▀${R}\n"
    printf '\n'
    printf " ${D}deploy smart contracts from forge scripts${R}\n"
    printf '\n'
  else
    cat <<'EOF'

 ▀█▀ █▀▄ █▀▀ █▀▄ █ █ █▀▀ █ █ █▀▀ ▀█▀
  █  █▀▄ █▀▀ █▀▄ █ █ █   █▀█ █▀▀  █
  ▀  ▀ ▀ ▀▀▀ ▀▀  ▀▀▀ ▀▀▀ ▀ ▀ ▀▀▀  ▀

 deploy smart contracts from forge scripts

EOF
  fi
}

usage() {
  cat <<'EOF'
trebup — installer for treb

USAGE:
    trebup [OPTIONS]

OPTIONS:
    -h, --help            Print this help message
    -v, --version         Print trebup version
    -i, --install TAG     Install a specific version
    -u, --use TAG         Switch to an already-installed version
    -l, --list            List installed versions
    --foundry CHANNEL     Foundry channel: stable (default) or nightly
    -U, --update          Update trebup itself

EXAMPLES:
    trebup                              Install latest treb nightly (foundry stable)
    trebup --foundry nightly            Install latest treb nightly (foundry nightly)
    trebup --install v2.1.0             Install treb stable
    trebup --install v1-nightly         Install Go nightly
    trebup --list                       List installed versions
    trebup --use v2-nightly-a5f2ae0--foundry-v1.5.1
EOF
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    err "need '$1' (command not found)"
  fi
}

say() {
  echo "trebup: $*"
}

warn() {
  echo "trebup: warning: $*" >&2
}

err() {
  echo "trebup: error: $*" >&2
  exit 1
}

ensure() {
  "$@"
  local status=$?
  if [ $status -ne 0 ]; then
    err "command failed: $*"
  fi
}

# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

# Install trebup itself to ~/.treb/bin/ when running for the first time
install_trebup

main "$@"
# v2.0.0
