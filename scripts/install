#!/usr/bin/env bash
set -eo pipefail

# Installs trebup (the treb version manager) to ~/.treb/bin/
# and adds it to PATH.
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/trebuchet-org/treb-cli-rs/main/scripts/install | bash

echo "Installing trebup..."

TREB_DIR="${TREB_DIR:-"$HOME/.treb"}"
TREB_BIN_DIR="$TREB_DIR/bin"

BIN_URL="https://raw.githubusercontent.com/trebuchet-org/treb-cli-rs/main/scripts/trebup"
BIN_PATH="$TREB_BIN_DIR/trebup"

# Download trebup
mkdir -p "$TREB_BIN_DIR"
curl -sSf -L "$BIN_URL" -o "$BIN_PATH"
chmod +x "$BIN_PATH"

# Detect shell and profile file
case $SHELL in
*/zsh)
    PROFILE="${ZDOTDIR-"$HOME"}/.zshenv"
    PREF_SHELL=zsh
    ;;
*/bash)
    PROFILE=$HOME/.bashrc
    PREF_SHELL=bash
    ;;
*/fish)
    PROFILE="${XDG_CONFIG_HOME:-$HOME/.config}/fish/config.fish"
    PREF_SHELL=fish
    ;;
*)
    PROFILE=$HOME/.profile
    PREF_SHELL=sh
    ;;
esac

# Add to PATH if not already there
if [[ ":$PATH:" != *":${TREB_BIN_DIR}:"* ]]; then
    if [[ "$PREF_SHELL" == "fish" ]]; then
        echo >> "$PROFILE" && echo "fish_add_path -a $TREB_BIN_DIR" >> "$PROFILE"
    else
        echo >> "$PROFILE" && echo "export PATH=\"\$PATH:$TREB_BIN_DIR\"" >> "$PROFILE"
    fi
fi

cat <<EOF

Detected your preferred shell is $PREF_SHELL and added trebup to PATH.
Run 'source $PROFILE' or start a new terminal session to use trebup.
Then, simply run 'trebup' to install treb.
EOF
