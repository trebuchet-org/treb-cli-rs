$ treb gen-deploy MathLib --strategy create --output script/DeployMathLib.s.sol
Generated deploy script: script/DeployMathLib.s.sol

--- script/DeployMathLib.s.sol ---
// SPDX-License-Identifier: UNLICENSED
pragma solidity ^<VERSION>;

import {Script, console} from "forge-std/Script.sol";
import { MathLib } from "../src/MathLib.sol";

contract DeployMathLib is Script {
    function run() public {
        vm.startBroadcast();

        // Library deployment — deploy raw bytecode
        bytes memory bytecode = type(MathLib).creationCode;
        address deployed;
        assembly {
            deployed := create(0, add(bytecode, 0x20), mload(bytecode))
        }
        require(deployed != address(0), "MathLib deployment failed");

        console.log("MathLib deployed at:", deployed);

        vm.stopBroadcast();
    }
}
